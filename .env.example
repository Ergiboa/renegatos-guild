# =============================================
# RENEGATOS GUILD PORTAL - Variables de entorno
# =============================================
# Copia este archivo como .env.local para desarrollo local
# En Vercel: añade estas variables en Settings > Environment Variables

# --- Comlink (datos públicos del juego) ---
# URL del servidor Comlink. Usa el de Kidori si no tienes el tuyo propio.
COMLINK_URL=https://comlink.kaiwu.dev

# --- Mandalorian Bot (datos internos autenticados) ---
# NUNCA subas estos valores a GitHub
MANDO_URL=https://mhanndalorianbot.work/api
MANDO_ACCOUNT_ID=TU_ACCOUNT_ID_AQUI
MANDO_PASSWORD=TU_PASSWORD_AQUI

# --- Guild ---
# ID del gremio ReneGatos (se obtiene con Get Guild ID en el Excel)
GUILD_ID=TU_GUILD_ID_AQUI
